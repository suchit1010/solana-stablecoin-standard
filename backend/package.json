{
  "name": "@stbr/sss-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend services for the Solana Stablecoin Standard",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/services/mint-burn/index.ts",
    "dev:indexer": "ts-node-dev --respawn src/services/indexer/index.ts",
    "dev:compliance": "ts-node-dev --respawn src/services/compliance/index.ts",
    "dev:webhook": "ts-node-dev --respawn src/services/webhook/index.ts",
    "test": "mocha --require ts-node/register 'tests/**/*.ts' --timeout 30000"
  },
  "dependencies": {
    "@stbr/sss-token": "file:../sdk/core",
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.0",
    "@solana/spl-token": "^0.4.12",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "ioredis": "^5.4.1",
    "winston": "^3.13.1",
    "cors": "^2.8.5",
    "bs58": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.11.6",
    "@types/node": "^20.14.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}

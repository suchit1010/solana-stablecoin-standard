# Solana Stablecoin Standard — Backend Environment Configuration

# ─── Solana (Devnet) ──────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# For local testing (anchor test):
# SOLANA_RPC_URL=http://localhost:8899
# SOLANA_WS_URL=ws://localhost:8900

# ─── Authority Keypair ────────────────────────────────────────────
# Easiest: just point to your Solana keypair JSON file
KEYPAIR_PATH=/home/shre/.config/solana/id.json

# Alternative: base58-encoded secret key string
# AUTHORITY_KEYPAIR=<your-base58-encoded-private-key>

# ─── Program IDs (Devnet — deployed 2026-03-10) ───────────────────
SSS_PROGRAM_ID=HJ6TUXQ34XhDrmvcozMsBWhSuEVkEcYeqoTWo1Bcmzet
SSS_HOOK_PROGRAM_ID=6x8XMLoA9FFmVJnaDou9tyKrh9CFynDY7TtKJ54p4dcN

# ─── Database (PostgreSQL) ────────────────────────────────────────
DATABASE_URL=postgres://sss:sss_password@localhost:5432/sss_stablecoin

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Webhook (SSS-2) ─────────────────────────────────────────────
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY_MS=5000
